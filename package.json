{
  "name": "multi-agent-framework",
  "version": "1.5.0",
  "description": "A flexible multi-agent collaboration framework for AI-powered software development",
  "main": "core/index.js",
  "bin": {
    "maf": "./cli/index.js"
  },
  "scripts": {
    "init": "node cli/index.js init",
    "agent": "node cli/index.js agent",
    "task": "node cli/index.js task",
    "message": "node cli/index.js message",
    "workflow": "node cli/index.js workflow",
    "watch": "node cli/index.js watch",
    "web": "node web/api/server.js",
    "web:dev": "node web/api/server.js",
    "start": "node web/api/server.js",
    "dashboard:install": "cd web/dashboard && npm install",
    "dashboard:build": "cd web/dashboard && npm run build",
    "dashboard:start": "cd web/dashboard && npm start",
    "build": "npm run dashboard:install && npm run dashboard:build",
    "dev": "npm run build && npm run web"
  },
  "keywords": [
    "multi-agent",
    "ai",
    "collaboration",
    "workflow",
    "automation",
    "software-development"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/multi-agent-framework"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "core/",
    "cli/",
    "templates/",
    "presets/",
    "web/"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "socket.io": "^4.7.0"
  }
}
